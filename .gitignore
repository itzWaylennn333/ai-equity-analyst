# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.pytest_cache/

# Virtual envs
.venv/
venv/
env/

# OS / editor
.DS_Store
Thumbs.db
*.tmp
*.swp

# transient render artifacts
outputs/_pdf_preview/
note/*.aux
note/*.log

# Per-ticker generated outputs are regenerable (`python run.py --ticker X`).
# Keep only the PYPL deliverable (flat outputs/charts, outputs/tables, outputs/research_note.pdf).
outputs/*/
!outputs/charts/
!outputs/tables/
data/processed/historical_*.csv
data/processed/dcf_projection_*.csv
# regenerable RAG vector index (binary; rebuild via rag.build_index)
data/processed/*/lancedb/

# NOTE: data/ and outputs/ are intentionally NOT ignored.
# Committing cached raw pulls + processed data + generated charts means the
# analysis reproduces from a clean checkout WITHOUT a network connection, and
# every figure's provenance is auditable via data/raw/_manifest.json.
